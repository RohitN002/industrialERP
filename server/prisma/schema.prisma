generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  refreshTokenHash String?
  isActive         Boolean    @default(true)
  passwordHash     String
  name             String
  customer         Customer?
  employee         Employee?
  supplier         Supplier?
   ownedOrganization Organization? @relation("OrganizationOwner")
  roles            UserRole[]
    organizationMemberships OrganizationMember[]
}
model OrganizationMember {
  id             String @id @default(uuid())

  userId         String
  organizationId String

  role           String // OWNER, ADMIN, EMPLOYEE

  user           User @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}
model Role {
  id    String     @id @default(uuid())
  name  RoleType   @unique
  users UserRole[]
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model BankAccount {
  id                String    @id @default(uuid())
  accountHolderName String
  accountNumber     String    @unique
  bankName          String
  branchName        String?
  ifscCode          String?
  upiId             String?
  isPrimary         Boolean   @default(false)
  isActive          Boolean   @default(true)
  supplierId        String?
  employeeId        String?
  clientId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  client            Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  supplier          Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model Employee {
  id                 String              @id @default(uuid())
  userId             String              @unique
  createdAt          DateTime            @default(now())
  address            String?
  city               String?
  country            String?
  dateOfBirth        DateTime?
  fatherName         String?
  gender             String?
  mobileNumber       String              @unique
  motherName         String?
  pincode            String?
  state              String?
  contactPerson      String?
  contactPersonPhone String?
  departmentId       String?
  designationId      String?
  attendances        Attendance[]
  bankAccounts       BankAccount[]
  leads              Client[]            @relation("AssignedLeads")
  createdLeads       Client[]            @relation("CreatedLeads")
  department         Department?         @relation(fields: [departmentId], references: [id])
  designation        Designation?        @relation(fields: [designationId], references: [id])
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedOrders     Order[]             @relation("AssignedOrders")
  createdOrders      Order[]             @relation("CreatedOrders")
  orders             OrderEmployee[]
  payrolls           Payroll[]
  productions        Production[]
  purchases          Purchase[]
  inspections        QualityInspection[]
  salaryStructures   SalaryStructure[]
  sales              Sale[]
  shiftAssignments   ShiftAssignment[]

  @@index([userId])
}

model SalaryStructure {
  id            String     @id @default(uuid())
  employeeId    String
  baseSalary    Int?
  perDayRate    Int?
  perHourRate   Int?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime   @default(now())
  type          SalaryType
  employee      Employee   @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id            String              @id @default(uuid())
  employeeId    String
  month         Int
  year          Int
  totalDays     Int
  presentDays   Int
  absentDays    Int
  workedMinutes Int
  grossSalary   Int
  deductions    Int
  netSalary     Int
  status        PayrollStatus       @default(PENDING)
  generatedAt   DateTime            @default(now())
  baseSalary    Int?
  perDayRate    Int?
  perHourRate   Int?
  salaryType    SalaryType
  employee      Employee            @relation(fields: [employeeId], references: [id])
  adjustments   PayrollAdjustment[]

  @@unique([employeeId, month, year])
}

model PayrollAdjustment {
  id        String         @id @default(uuid())
  payrollId String
  type      AdjustmentType
  amount    Int
  reason    String?
  createdAt DateTime       @default(now())
  payroll   Payroll        @relation(fields: [payrollId], references: [id])
}

model OrderEmployee {
  id         String   @id @default(uuid())
  orderId    String
  employeeId String
  role       String
  employee   Employee @relation(fields: [employeeId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, employeeId, role])
}

model Customer {
  id        String   @id @default(uuid())
  userId    String?  @unique
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  sales     Sale[]

  @@index([userId])
}

model Product {
  id                    String           @id @default(uuid())
  name                  String
  sku                   String           @unique
  description           String?
  price                 Decimal          @db.Decimal(12, 2)
  createdAt             DateTime         @default(now())
  imageUrl              String?
  stockQuantity         Int
  type                  String
  unit                  String?
  categoryId            String
  supplierId            String?
  orderItems            OrderItem[]
  category              Category         @relation(fields: [categoryId], references: [id])
  supplier              Supplier?        @relation(fields: [supplierId], references: [id])
  productionsAsFinished Production[]     @relation("FinishedProduct")
  productionItems       ProductionItem[]
  purchaseItems         PurchaseItem[]
  quoteItems            QuoteItem[]
  saleItems             SaleItem[]
}

model Purchase {
  id          String              @id @default(uuid())
  referenceNo String              @unique
  createdById String
  createdAt   DateTime            @default(now())
  createdBy   Employee            @relation(fields: [createdById], references: [id])
  items       PurchaseItem[]
  inspections QualityInspection[]

  @@index([createdById])
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@unique([purchaseId, productId])
  @@index([purchaseId])
  @@index([productId])
}

model Supplier {
  id                 String        @id @default(uuid())
  userId             String        @unique
  phone              String
  address            String
  createdAt          DateTime      @default(now())
  city               String
  contactPerson      String
  contactPersonPhone String
  country            String
  gst                String
  pincode            String
  state              String
  bankAccounts       BankAccount[]
  products           Product[]
  user               User          @relation(fields: [userId], references: [id])
}

model Sale {
  id          String     @id @default(uuid())
  invoiceNo   String     @unique
  status      SaleStatus @default(DRAFT)
  customerId  String
  createdById String
  createdAt   DateTime   @default(now())
  createdBy   Employee   @relation(fields: [createdById], references: [id])
  customer    Customer   @relation(fields: [customerId], references: [id])
  items       SaleItem[]

  @@index([customerId])
  @@index([createdById])
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([saleId, productId])
  @@index([saleId])
  @@index([productId])
}

model Production {
  id                String              @id @default(uuid())
  batchNo           String              @unique
  status            ProductionStatus    @default(PLANNED)
  producedProductId String
  createdById       String
  createdAt         DateTime            @default(now())
  createdBy         Employee            @relation(fields: [createdById], references: [id])
  producedProduct   Product             @relation("FinishedProduct", fields: [producedProductId], references: [id])
  items             ProductionItem[]
  inspections       QualityInspection[]

  @@index([producedProductId])
  @@index([createdById])
}

model ProductionItem {
  id           String     @id @default(uuid())
  productionId String
  productId    String
  quantity     Int
  product      Product    @relation(fields: [productId], references: [id])
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@unique([productionId, productId])
  @@index([productionId])
  @@index([productId])
}

model QualityInspection {
  id            String        @id @default(uuid())
  status        QualityStatus @default(PENDING)
  remarks       String?
  productionId  String?
  purchaseId    String?
  inspectedById String
  createdAt     DateTime      @default(now())
  inspectedBy   Employee      @relation(fields: [inspectedById], references: [id])
  production    Production?   @relation(fields: [productionId], references: [id])
  purchase      Purchase?     @relation(fields: [purchaseId], references: [id])

  @@index([productionId])
  @@index([purchaseId])
  @@index([inspectedById])
}

model Shift {
  id            String            @id @default(uuid())
  name          String
  startTime     String
  endTime       String
  isOvernight   Boolean           @default(false)
  graceInMin    Int               @default(0)
  graceOutMin   Int               @default(0)
  minHalfDayMin Int?
  minFullDayMin Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  attendances   Attendance[]
  assignments   ShiftAssignment[]
}

model ShiftAssignment {
  id       String   @id @default(uuid())
  userId   String
  shiftId  String
  date     DateTime
  shift    Shift    @relation(fields: [shiftId], references: [id])
  employee Employee @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Attendance {
  id            String           @id @default(uuid())
  userId        String
  date          DateTime         @db.Date
  status        AttendanceStatus
  checkIn       DateTime?
  checkOut      DateTime?
  createdAt     DateTime         @default(now())
  shiftId       String?
  updatedAt     DateTime         @updatedAt
  workedMinutes Int?
  source        AttendanceSource @default(MANUAL)
  workedHours   Int?
  shift         Shift?           @relation(fields: [shiftId], references: [id])
  employee      Employee         @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Designation {
  id        String     @id @default(uuid())
  name      String
  employees Employee[]
}

model Department {
  id        String     @id @default(uuid())
  name      String
  employees Employee[]
}

model Client {
  id                 String        @id @default(uuid())
  name               String
  email              String?       @unique
  phone              String?       @unique
  company            String?       @unique
  source             String?
  status             LeadStatus    @default(NEW)
  address            String?
  city               String?
  state              String?
  pincode            String?
  country            String?
  contactPerson      String?
  contactPersonPhone String?
  gst                String?       @unique
  assignedToId       String?
  createdById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  logoUrl            String?
  bankAccounts       BankAccount[]
  assignedTo         Employee?     @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdBy          Employee?     @relation("CreatedLeads", fields: [createdById], references: [id])
  orders             Order[]
  quotes             Quote[]

  @@index([assignedToId])
  @@index([createdById])
}

model Industries {
  id   String @id @default(dbgenerated("gen_random_uuid()"))
  name String @unique
}

model Organization {
  id                    String  @id @default(uuid())
  OrganizationName      String
  industry              String
  OrganizationLocation  String
  OrganizationAddress   String
  websiteUrl            String
  primaryMail           String
  primaryPhone          String
  EmailforBilling       String?
  baseCurrency          String  @default("INR")
  reportBasis           String?
  organizationLanguage  String?
  communicationLanguage String?
  companyId             String?
  logoUrl               String?
  ownerId String @unique
  owner   User @relation("OrganizationOwner", fields: [ownerId], references: [id])
   members OrganizationMember[]
}

model Order {
  id                   String          @id @default(uuid())
  assignedToId         String?
  createdById          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  currency             String          @default("INR")
  notes                String?
  orderDate            DateTime        @default(now())
  orderNumber          String          @unique
  paymentMethod        String?
  paymentStatus        String          @default("Unpaid")
  priority             String?
  shippingAddress      String?
  shippingCity         String?
  shippingContact      String?
  shippingCountry      String?
  shippingPhone        String?
  shippingPincode      String?
  shippingState        String?
  status               String          @default("Pending")
  subTotal             Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount          Decimal         @default(0) @db.Decimal(12, 2)
  totalDiscount        Decimal         @default(0) @db.Decimal(12, 2)
  totalTax             Decimal         @default(0) @db.Decimal(12, 2)
  expectedDeliveryDate DateTime?
  billingAddress       String?
  shippingMethod       String?
  grandTotal           Decimal         @default(0) @db.Decimal(12, 2)
  shippingCost         Decimal         @default(0) @db.Decimal(12, 2)
  clientId             String?
  assignedTo           Employee?       @relation("AssignedOrders", fields: [assignedToId], references: [id])
  client               Client?         @relation(fields: [clientId], references: [id])
  createdBy            Employee?       @relation("CreatedOrders", fields: [createdById], references: [id])
  employees            OrderEmployee[]
  items                OrderItem[]
}

model Quote {
  id                   String      @id @default(uuid())
  quoteNumber          String      @unique
  version              Int         @default(1)
  clientId             String
  issueDate            DateTime    @default(now())
  expiryDate           DateTime?
  status               QuoteStatus @default(DRAFT)
  currency             String      @default("INR")
  subTotal             Decimal     @db.Decimal(12, 2)
  taxTotal             Decimal     @db.Decimal(12, 2)
  discountTotal        Decimal     @db.Decimal(12, 2)
  grandTotal           Decimal     @db.Decimal(12, 2)
  notes                String?
  terms                String?
  convertedToOrderId   String?
  convertedToInvoiceId String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  quoteName            String      @unique
  client               Client      @relation(fields: [clientId], references: [id])
  items                QuoteItem[]

  @@index([clientId])
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  productId   String?
  description String?
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  tax         Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)
  sortOrder   Int?
  createdAt   DateTime @default(now())
  product     Product? @relation(fields: [productId], references: [id])
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int?
  unitPrice Decimal? @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  tax       Decimal  @default(0) @db.Decimal(12, 2)
  total     Decimal  @default(0) @db.Decimal(12, 2)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

enum RoleType {
  ADMIN
  MANAGER
  SALES
  PRODUCTION
  QUALITY
  CUSTOMER
  SUPPLIER
  EMPLOYEE
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  SHIPPED
  CANCELLED
}

enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
}

enum QualityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  PENDING
  GENERATED
  PAID
  FAILED
}

enum AdjustmentType {
  BONUS
  DEDUCTION
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  CONVERTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HOLIDAY
  HALF_DAY
  ON_LEAVE
  WEEKEND
}

enum AttendanceSource {
  MANUAL
  BIOMETRIC
  SYSTEM
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  NEGOTIATION
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}
