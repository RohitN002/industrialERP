  // This is your Prisma schema file,
  // learn more about it in the docs: https://pris.ly/d/prisma-schema

  // Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
  // Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

  generator client {
    provider = "prisma-client-js"
     
  }

  datasource db {
    provider = "postgresql"

  }



/////////////////////
// ENUMS
/////////////////////

enum RoleType {
  EMPLOYEE
  ADMIN
  MANAGER
  SALES
  PRODUCTION
  QUALITY
  CUSTOMER
  SUPPLIER
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  SHIPPED
  CANCELLED
}
enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
}

enum QualityStatus {
  PENDING
  APPROVED
  REJECTED
}

/////////////////////
// CORE IDENTITY
/////////////////////

model User {
  id            String   @id @default(uuid())
  email         String   @unique

  passwordHash  String
  isActive      Boolean  @default(true)
name            String
  roles         UserRole[]
    employee      Employee?
  customer      Customer?
  supplier      Supplier?
  refreshTokenHash String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Role {
  id        String     @id @default(uuid())
  name      RoleType   @unique
  users     UserRole[]
}
model Category{
  id String @id @default(uuid())
  name String @unique
  products Product[]
}
model UserRole {
    userId String
    roleId String

    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
    role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

    @@id([userId, roleId])
  }

/////////////////////
// EMPLOYEE & CUSTOMER
/////////////////////

model Employee {
  id        String  @id @default(uuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mobileNumber  String   @unique
 
   salaryStructures SalaryStructure[]
  payrolls         Payroll[]
  dateOfBirth DateTime?
  gender String?
fatherName String?
  motherName String?
  address String?
  city String?
  state String?
  contactPerson String?
  contactPersonPhone String?
  pincode String?
  country String?
  productions Production[]
  sales       Sale[]
  purchases   Purchase[]
  shiftAssignments ShiftAssignment[]
   assignedOrders Order[] @relation("AssignedOrders")
  createdOrders  Order[] @relation("CreatedOrders")
   orders        OrderEmployee[]
  inspections QualityInspection[]
  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])
  departmentId String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  leads       Client[] @relation("AssignedLeads")
  createdLeads Client[] @relation("CreatedLeads")
attendances  Attendance[]
  createdAt   DateTime @default(now())
    @@index([userId])
}
model SalaryStructure {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])

  type        SalaryType

  baseSalary  Int?
  perDayRate  Int?
  perHourRate Int?

  effectiveFrom DateTime
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
}

model Payroll {
  id          String   @id @default(uuid())

  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])

  month       Int
  year        Int

  totalDays       Int
  presentDays     Int
  absentDays      Int
  workedMinutes   Int

  grossSalary     Int
  deductions      Int
  netSalary       Int
  salaryType     SalaryType
  baseSalary     Int?
  perDayRate     Int?
  perHourRate    Int?
  status PayrollStatus @default(PENDING)
adjustments PayrollAdjustment[]
  generatedAt DateTime @default(now())

  @@unique([employeeId, month, year])
}
enum PayrollStatus {
  PENDING
  GENERATED
  PAID
  FAILED
}
enum AdjustmentType {
  BONUS
  DEDUCTION
}
model PayrollAdjustment {
  id         String   @id @default(uuid())
  payrollId  String
  payroll    Payroll  @relation(fields: [payrollId], references: [id])

  type       AdjustmentType // BONUS | DEDUCTION
  amount     Int
  reason     String?

  createdAt DateTime @default(now())
}
model OrderEmployee {
  id          String   @id @default(uuid())

  orderId     String
  employeeId  String
  role        String   

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@unique([orderId, employeeId, role]) // optional but useful
}
model Customer {
  id        String  @id @default(uuid())
  userId    String? @unique
  user      User?   @relation(fields: [userId], references: [id])


  phone     String?
  address   String?

  sales     Sale[]
 @@index([userId])
  createdAt DateTime @default(now())
}

/////////////////////
// PRODUCT
/////////////////////

model Product {
  id          String  @id @default(uuid())
  name        String
  sku         String  @unique
  description String?   
  price       Decimal @db.Decimal(12,2)
  stockQuantity Int
  type        String
  unit        String?
 supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
 orderItems OrderItem[]
 quoteItems QuoteItem[]
  imageUrl    String?
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  productionItems ProductionItem[]
  categoryId String
  category Category @relation(fields: [categoryId], references: [id])
  // ✅ Correct inverse relation
  productionsAsFinished Production[] @relation("FinishedProduct")

  createdAt DateTime @default(now())
}
/////////////////////
// PURCHASE
/////////////////////

model Purchase {
  id          String @id @default(uuid())
  referenceNo String @unique

  createdById String
  createdBy   Employee @relation(fields: [createdById], references: [id])

  items       PurchaseItem[]
  inspections QualityInspection[]
  @@index([createdById])
  createdAt   DateTime @default(now())
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12,2)
 @@index([purchaseId])
  @@index([productId])
  @@unique([purchaseId, productId])
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
}

/////////////////////
// SALES
///////////////////// 

model Supplier {
  id        String  @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id])
 products  Product[]
  phone     String
  address   String
  city String
  state String
  pincode String
  country String
  contactPerson String
  contactPersonPhone String
  gst String
  createdAt DateTime @default(now())
}
model Sale {
  id          String     @id @default(uuid())
  invoiceNo   String     @unique
  status      SaleStatus @default(DRAFT)

  customerId  String
  customer    Customer   @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   Employee   @relation(fields: [createdById], references: [id])

  items       SaleItem[]
  @@index([customerId])
  @@index([createdById])
  createdAt   DateTime   @default(now())
}

model SaleItem {
  id        String @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12,2)
 @@index([saleId])
  @@index([productId])
  @@unique([saleId, productId])
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

/////////////////////
// PRODUCTION
/////////////////////

model Production {
  id          String           @id @default(uuid())
  batchNo     String           @unique
  status      ProductionStatus @default(PLANNED)

  producedProductId String
  producedProduct   Product @relation("FinishedProduct", fields: [producedProductId], references: [id])

  createdById String
  createdBy   Employee @relation(fields: [createdById], references: [id])

  items       ProductionItem[]
  inspections QualityInspection[]
 @@index([producedProductId])
  @@index([createdById])
  createdAt   DateTime @default(now())
}

model ProductionItem {
  id           String @id @default(uuid())
  productionId String
  productId    String
  quantity     Int
 @@index([productionId])
  @@index([productId])
  @@unique([productionId, productId])
  production Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])
}

/////////////////////
// QUALITY
/////////////////////

model QualityInspection {
  id            String        @id @default(uuid())
  status        QualityStatus @default(PENDING)
  remarks       String?

  productionId  String?
  purchaseId    String?

  production Production? @relation(fields: [productionId], references: [id])
  purchase   Purchase?   @relation(fields: [purchaseId], references: [id])

  inspectedById String
  inspectedBy   Employee @relation(fields: [inspectedById], references: [id])
@@index([productionId])
  @@index([purchaseId])
  @@index([inspectedById])
  createdAt     DateTime @default(now())
}

/////////////////////
// LEADS & CRM
/////////////////////

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  CONVERTED
}
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  WEEKEND
  HOLIDAY
}
model Shift {
  id            String   @id @default(uuid())

  name          String   // "General Shift", "Night Shift"

  startTime     String   // "09:00"
  endTime       String   // "18:00"

  isOvernight   Boolean  @default(false)

  graceInMin    Int      @default(0)  // allowed late minutes
  graceOutMin   Int      @default(0)  // early leave tolerance

  minHalfDayMin Int?     // below this = half day
  minFullDayMin Int?     // required for full day
  assignments ShiftAssignment[]
  attendances Attendance[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model ShiftAssignment {
  id        String   @id @default(uuid())

  userId    String
  employee  Employee @relation(fields: [userId], references: [id])

  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id])

  date      DateTime // IMPORTANT: per-day assignment

  @@unique([userId, date])
}
enum AttendanceSource {
  MANUAL
  BIOMETRIC
  SYSTEM
}
model Attendance {
  id            String   @id @default(uuid())

  userId        String
  employee      Employee @relation(fields: [userId], references: [id])

  date DateTime @db.Date

  status        AttendanceStatus

  checkIn       DateTime?
  checkOut      DateTime?

  workedMinutes Int?     // derived or stored for performance
  workedHours Int?
  shiftId       String?
  shift         Shift?   @relation(fields: [shiftId], references: [id])

  source AttendanceSource @default(MANUAL)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, date])
}
model Designation{
  id String @id @default(uuid())
  name String
  employees Employee[]
}
model Department{
  id String @id @default(uuid())
  name String
  employees Employee[]
}
model Client {
  id          String     @id @default(uuid())
  name        String
  email       String?
  phone       String?
  company     String?
  source      String?
  status      LeadStatus @default(NEW)
   quotes  Quote[] 
  address String?
  city String?
  state String?
  pincode String?
  country String?
  contactPerson String?
  contactPersonPhone String?
  gst String?
  assignedToId String?
  assignedTo   Employee?  @relation("AssignedLeads", fields: [assignedToId], references: [id])
  orders Order[]
  createdById String?
  createdBy   Employee?   @relation("CreatedLeads", fields: [createdById], references: [id])
@@index([assignedToId])
  @@index([createdById])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Order {
  id String @id @default(uuid())

  // Relations to employees
  assignedToId String?
  assignedTo Employee? @relation("AssignedOrders", fields: [assignedToId], references: [id])
  createdById String?
  createdBy Employee? @relation("CreatedOrders", fields: [createdById], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Customer / sales info
 clientId String?
  client Client? @relation(fields: [clientId], references: [id])
  orderNumber String @unique
  orderDate DateTime @default(now())
  expectedDeliveryDate DateTime?
  status String @default("Pending") // Pending, Confirmed, Shipped, Delivered, Cancelled
  priority String?

  // Financial fields (calculated in application)
  subTotal Decimal @db.Decimal(12,2) @default(0) // sum of items unitPrice * quantity
  totalDiscount Decimal @db.Decimal(12,2) @default(0) // sum of item discounts
  totalTax Decimal @db.Decimal(12,2) @default(0)      // sum of item taxes
  totalAmount Decimal @db.Decimal(12,2) @default(0)   // subTotal - totalDiscount + totalTax
  paymentStatus String @default("Unpaid")
  paymentMethod String?
  currency String @default("INR")

  // Shipping info
  billingAddress String?
  shippingAddress String?
  shippingCity String?
  shippingState String?
  shippingCountry String?
  shippingPincode String?
  shippingContact String?
  shippingPhone String?
shippingMethod String?
shippingCost Decimal @db.Decimal(12,2) @default(0)
  // Relations
  items OrderItem[]
  employees OrderEmployee[]
grandTotal Decimal @db.Decimal(12,2) @default(0)
  // Optional notes
  notes String?
}
model Quote {
  id              String   @id @default(uuid())

  quoteNumber     String   @unique
  version         Int      @default(1)

 clientId      String
  client        Client @relation(fields: [clientId], references: [id])

  issueDate       DateTime @default(now())
  expiryDate      DateTime?

  status          QuoteStatus @default(DRAFT)

  currency        String   @default("INR")
items QuoteItem[]
  subTotal        Decimal  @db.Decimal(12,2)
  taxTotal        Decimal  @db.Decimal(12,2)
  discountTotal   Decimal  @db.Decimal(12,2)
  grandTotal      Decimal  @db.Decimal(12,2)

  notes           String?
  terms           String?

  // Conversion tracking
  convertedToOrderId String?
  convertedToInvoiceId String?



  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
}
enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  NEGOTIATION
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}
model QuoteItem {
  id          String  @id @default(uuid())

  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId   String?
  product     Product? @relation(fields: [productId], references: [id])

  description String

  quantity    Decimal @db.Decimal(10,2)
  unitPrice   Decimal @db.Decimal(12,2)

  discount    Decimal @db.Decimal(12,2) @default(0)
  tax         Decimal @db.Decimal(12,2) @default(0)

  lineTotal   Decimal @db.Decimal(12,2)

  sortOrder   Int?

  createdAt   DateTime @default(now())
}
model OrderItem {
  id String @id @default(uuid())
  orderId String
  productId String
  quantity Int?
  unitPrice Decimal? @db.Decimal(12,2)
  discount Decimal @db.Decimal(12,2) @default(0) // per item
  tax Decimal @db.Decimal(12,2) @default(0)      // per item
  total Decimal @db.Decimal(12,2) @default(0)    // calculated: (unitPrice*quantity - discount + tax)
  
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}