  // This is your Prisma schema file,
  // learn more about it in the docs: https://pris.ly/d/prisma-schema

  // Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
  // Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

  generator client {
    provider = "prisma-client-js"
     
  }

  datasource db {
    provider = "postgresql"

  }


  

/////////////////////
// ENUMS
/////////////////////

enum RoleType {
  EMPLOYEE
  ADMIN
  MANAGER
  SALES
  PRODUCTION
  QUALITY
  CUSTOMER
  SUPPLIER
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  SHIPPED
  CANCELLED
}

enum QualityStatus {
  PENDING
  APPROVED
  REJECTED
}

/////////////////////
// CORE IDENTITY
/////////////////////

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  isActive      Boolean  @default(true)
name            String
  roles         UserRole[]
    employee      Employee?
  customer      Customer?
  supplier      Supplier?
  refreshTokenHash String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Role {
  id        String     @id @default(uuid())
  name      RoleType   @unique
  users     UserRole[]
}
model Category{
  id String @id @default(uuid())
  name String @unique
  products Product[]
}
model UserRole {
  userId String
  roleId String

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

/////////////////////
// EMPLOYEE & CUSTOMER
/////////////////////

model Employee {
  id        String  @id @default(uuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id])

  designation String?
  department  String?

  productions Production[]
  sales       Sale[]
  purchases   Purchase[]
  inspections QualityInspection[]
  leads       Lead[] @relation("AssignedLeads")
  createdLeads Lead[] @relation("CreatedLeads")
attendances  Attendance[]
  createdAt   DateTime @default(now())
    @@index([userId])
}

model Customer {
  id        String  @id @default(uuid())
  userId    String? @unique
  user      User?   @relation(fields: [userId], references: [id])


  phone     String?
  address   String?

  sales     Sale[]
 @@index([userId])
  createdAt DateTime @default(now())
}

/////////////////////
// PRODUCT
/////////////////////

model Product {
  id          String  @id @default(uuid())
  name        String
  sku         String  @unique
  description String?   
  price       Decimal @db.Decimal(12,2)
  stockQuantity Int
  type        String
  unit        String?
 supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  imageUrl    String?
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  productionItems ProductionItem[]
  categoryId String
  category Category @relation(fields: [categoryId], references: [id])
  // ✅ Correct inverse relation
  productionsAsFinished Production[] @relation("FinishedProduct")

  createdAt DateTime @default(now())
}
/////////////////////
// PURCHASE
/////////////////////

model Purchase {
  id          String @id @default(uuid())
  referenceNo String @unique

  createdById String
  createdBy   Employee @relation(fields: [createdById], references: [id])

  items       PurchaseItem[]
  inspections QualityInspection[]
  @@index([createdById])
  createdAt   DateTime @default(now())
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12,2)
 @@index([purchaseId])
  @@index([productId])
  @@unique([purchaseId, productId])
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
}

/////////////////////
// SALES
///////////////////// 

model Supplier {
  id        String  @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id])
 products  Product[]
  phone     String
  address   String
  city String
  state String
  pincode String
  country String
  contactPerson String
  contactPersonPhone String
  gst String
  createdAt DateTime @default(now())
}
model Sale {
  id          String     @id @default(uuid())
  invoiceNo   String     @unique
  status      SaleStatus @default(DRAFT)

  customerId  String
  customer    Customer   @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   Employee   @relation(fields: [createdById], references: [id])

  items       SaleItem[]
  @@index([customerId])
  @@index([createdById])
  createdAt   DateTime   @default(now())
}

model SaleItem {
  id        String @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12,2)
 @@index([saleId])
  @@index([productId])
  @@unique([saleId, productId])
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

/////////////////////
// PRODUCTION
/////////////////////

model Production {
  id          String           @id @default(uuid())
  batchNo     String           @unique
  status      ProductionStatus @default(PLANNED)

  producedProductId String
  producedProduct   Product @relation("FinishedProduct", fields: [producedProductId], references: [id])

  createdById String
  createdBy   Employee @relation(fields: [createdById], references: [id])

  items       ProductionItem[]
  inspections QualityInspection[]
 @@index([producedProductId])
  @@index([createdById])
  createdAt   DateTime @default(now())
}

model ProductionItem {
  id           String @id @default(uuid())
  productionId String
  productId    String
  quantity     Int
 @@index([productionId])
  @@index([productId])
  @@unique([productionId, productId])
  production Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])
}

/////////////////////
// QUALITY
/////////////////////

model QualityInspection {
  id            String        @id @default(uuid())
  status        QualityStatus @default(PENDING)
  remarks       String?

  productionId  String?
  purchaseId    String?

  production Production? @relation(fields: [productionId], references: [id])
  purchase   Purchase?   @relation(fields: [purchaseId], references: [id])

  inspectedById String
  inspectedBy   Employee @relation(fields: [inspectedById], references: [id])
@@index([productionId])
  @@index([purchaseId])
  @@index([inspectedById])
  createdAt     DateTime @default(now())
}

/////////////////////
// LEADS & CRM
/////////////////////

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  CONVERTED
}
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HOLIDAY
}
model Attendance{
  id String @id @default(uuid())
  userId String
   employee    Employee         @relation(fields: [userId], references: [id])
  date DateTime @default(now())
  status AttendanceStatus @default(PRESENT)
}
model Designation{
  id String @id @default(uuid())
  name String
}
model Department{
  id String @id @default(uuid())
  name String
}
model Lead {
  id          String     @id @default(uuid())
  name        String
  email       String?
  phone       String?
  company     String?
  source      String?
  status      LeadStatus @default(NEW)

  assignedToId String?
  assignedTo   Employee?  @relation("AssignedLeads", fields: [assignedToId], references: [id])

  createdById String
  createdBy   Employee   @relation("CreatedLeads", fields: [createdById], references: [id])
@@index([assignedToId])
  @@index([createdById])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}